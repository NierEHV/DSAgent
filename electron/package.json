{
  "name": "ds-agent-desktop",
  "version": "3.1.0",
  "description": "DS Agent — 跨境电商 AI 运营指挥中心 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "NODE_ENV=development electron .",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.dsagent.desktop",
    "productName": "DS Agent",
    "directories": {
      "output": "../dist-electron"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^25.0.0"
  }
}
