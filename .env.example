# DS Agent 环境变量配置
# 复制为 .env 并填写实际值

# ──── LLM API Keys ────
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ──── 领星 ERP ────
LINGXING_API_KEY=your_lingxing_api_key
LINGXING_BASE_URL=https://api.lingxing.com

# ──── 亚马逊 SP-API ────
AMAZON_SP_API_KEY=your_amazon_sp_api_key
AMAZON_SP_API_SECRET=your_secret
AMAZON_SP_REFRESH_TOKEN=your_refresh_token

# ──── 钉钉通知 ────
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx

# ──── 企微通知 ────
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ──── n8n ────
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# ──── 数据库 ────
DATABASE_URL=sqlite:///data/dsagent.db

# ──── Mock 模式（开发时使用模拟数据）────
MOCK_MODE=true
